# ============================================================================
# OmniPic — Environment Variables Template
# ============================================================================
# 1. Copy this file to `.env.local` in the project root.
# 2. Fill in the REAL values (never commit `.env.local` to git).
# 3. IMPORTANT: Any secret previously pasted in chat MUST be regenerated
#    from the respective provider dashboard before going to production.
# ============================================================================

# ----------------------------------------------------------------------------
# Next.js / App
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://tracks-thinking-wishes-side.trycloudflare.com
NEXTAUTH_URL=https://tracks-thinking-wishes-side.trycloudflare.com
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# ----------------------------------------------------------------------------
# Google OAuth (NextAuth provider)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ----------------------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# WARNING: service role key bypasses RLS — keep it server-side only!
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ----------------------------------------------------------------------------
# Stripe
# ----------------------------------------------------------------------------
# Use test keys (sk_test_..., pk_test_...) during development.
# Switch to live keys only for production.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
# Webhook secret from `stripe listen` or dashboard
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe product IDs (live) — map plans to Stripe products
STRIPE_PRODUCT_WEEKLY=prod_UIgGvMOGagd29p
STRIPE_PRODUCT_MONTHLY=prod_UIgHNZVLZj4YB3
STRIPE_PRODUCT_ANNUAL=prod_UIgIUYOhXrjGYJ

# Stripe price IDs — you must create these in the Stripe dashboard
# (each product should have one recurring price attached).
STRIPE_PRICE_WEEKLY=price_your_weekly_price_id
STRIPE_PRICE_MONTHLY=price_your_monthly_price_id
STRIPE_PRICE_ANNUAL=price_your_annual_price_id
